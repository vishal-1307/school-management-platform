# Database
# Local dev default (no .env needed): sqlite+aiosqlite:///./school.db
# Production: paste Neon's POOLED connection string as-is —
# postgres://, sslmode= and channel_binding= are normalized automatically.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth — signs session JWTs. Use a long random value in production
# (Render auto-generates one via render.yaml). Any string works locally.
SECRET_KEY=change-me-to-a-long-random-string
# Session lifetime in hours (default 24)
ACCESS_TOKEN_HOURS=24

# SEED_ON_START=true runs the idempotent demo seed at boot
# (see DEMO_CREDENTIALS.md; set false after wiping demo data).
SEED_ON_START=false

# Razorpay Payments (optional — online payments disabled until set)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx

# Cloudinary Media Storage (optional — uploads disabled until set)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# WhatsApp Cloud API (optional — messages logged as SKIPPED until set)
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_ID=000000000000000

# CORS — JSON array or comma-separated list, both accepted
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:4321"]

# Public URL of the frontend (used in WhatsApp links, receipts)
FRONTEND_URL=https://school-management-platform-five.vercel.app

# AI Assistant (optional — feature disabled until set; DigitalOcean Serverless
# Inference). AI_WIRE_FORMAT=openai talks to /v1/chat/completions (DeepSeek,
# GLM, Llama, GPT-* — Bearer auth, OpenAI tool-calling shape). Set
# AI_WIRE_FORMAT=anthropic + AI_BASE_URL=.../v1/messages to use a Claude model
# on DO or a direct Anthropic key instead — no other code changes needed.
DO_MODEL_ACCESS_KEY=
AI_BASE_URL=https://inference.do-ai.run/v1/chat/completions
AI_MODEL=deepseek-4-flash
AI_WIRE_FORMAT=openai
