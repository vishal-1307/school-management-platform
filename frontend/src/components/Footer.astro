---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: "About Us", href: "/about" },
  { label: "Academics", href: "/academics" },
  { label: "Admissions", href: "/admissions" },
  { label: "Faculty", href: "/faculty" },
  { label: "Gallery", href: "/gallery" },
  { label: "Achievements", href: "/achievements" },
  { label: "Facilities", href: "/facilities" },
  { label: "Contact Us", href: "/contact" },
];

const importantLinks = [
  { label: "Mandatory Public Disclosure", href: "/disclosure" },
  { label: "Notice Board", href: "/notices" },
  { label: "Portal Login", href: "/login" },
  { label: "Transfer Certificate", href: "/contact" },
  { label: "Fee Payment", href: "/contact" },
];
---

<footer class="bg-slate-900 text-slate-300 relative overflow-hidden">
  <!-- Decorative gradient bar -->
  <div class="h-1 gradient-primary"></div>

  <!-- Decorative blurred circle -->
  <div class="absolute top-20 -right-32 w-80 h-80 bg-primary-600/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-10 -left-20 w-60 h-60 bg-secondary-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">

      <!-- Column 1: School Info -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-12 h-12 rounded-xl gradient-primary flex items-center justify-center shadow-lg">
            <svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-bold text-white text-lg leading-tight">Knowledge Development</h3>
            <p class="text-xs text-primary-300 font-medium tracking-wider uppercase">Kindergarten Academy</p>
          </div>
        </div>
        <p class="text-slate-400 text-sm leading-relaxed mb-6">
          Nurturing young minds with excellence since 1998. A CBSE-affiliated institution committed to holistic education, character building, and academic brilliance.
        </p>
        <!-- Social Media -->
        <div class="flex items-center gap-3">
          <a href="#" class="w-10 h-10 rounded-xl bg-slate-800 hover:bg-primary-600 flex items-center justify-center transition-all duration-200 hover:-translate-y-1" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-xl bg-slate-800 hover:bg-pink-600 flex items-center justify-center transition-all duration-200 hover:-translate-y-1" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-xl bg-slate-800 hover:bg-sky-500 flex items-center justify-center transition-all duration-200 hover:-translate-y-1" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
          </a>
          <a href="#" class="w-10 h-10 rounded-xl bg-slate-800 hover:bg-red-600 flex items-center justify-center transition-all duration-200 hover:-translate-y-1" aria-label="YouTube">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h4 class="font-heading font-semibold text-white text-lg mb-6 flex items-center gap-2">
          <span class="w-8 h-0.5 bg-secondary-500 rounded-full"></span>
          Quick Links
        </h4>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-primary-300 transition-colors duration-200 flex items-center gap-2 group">
                <svg class="w-3 h-3 text-primary-500 group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                </svg>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact Info -->
      <div>
        <h4 class="font-heading font-semibold text-white text-lg mb-6 flex items-center gap-2">
          <span class="w-8 h-0.5 bg-secondary-500 rounded-full"></span>
          Contact Us
        </h4>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <div class="w-9 h-9 rounded-lg bg-primary-600/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm text-slate-300">123, Knowledge Lane, Sector 15</p>
              <p class="text-sm text-slate-400">New Delhi — 110001</p>
            </div>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-primary-600/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <a href="tel:+911234567890" class="text-sm text-slate-300 hover:text-primary-300 transition-colors">+91 12345 67890</a>
              <p class="text-xs text-slate-500">Mon–Sat, 8AM – 3PM</p>
            </div>
          </li>
          <li class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-primary-600/20 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <a href="mailto:info@knowledgeacademy.edu.in" class="text-sm text-slate-300 hover:text-primary-300 transition-colors">info@knowledgeacademy.edu.in</a>
          </li>
        </ul>

        <!-- Important Links -->
        <div class="mt-8">
          <h5 class="text-sm font-semibold text-white mb-3">Important</h5>
          <ul class="space-y-2">
            {importantLinks.map((link) => (
              <li>
                <a href={link.href} class="text-xs text-slate-400 hover:text-secondary-400 transition-colors flex items-center gap-1.5">
                  <svg class="w-3 h-3 text-secondary-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Column 4: Map + Disclosure -->
      <div>
        <h4 class="font-heading font-semibold text-white text-lg mb-6 flex items-center gap-2">
          <span class="w-8 h-0.5 bg-secondary-500 rounded-full"></span>
          Find Us
        </h4>
        <!-- Map Embed -->
        <div class="rounded-xl overflow-hidden border border-slate-700 mb-6">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3502.0!2d77.2!3d28.6!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjjCsDM2JzAwLjAiTiA3N8KwMTInMDAuMCJF!5e0!3m2!1sen!2sin!4v1"
            width="100%"
            height="180"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="School Location"
          ></iframe>
        </div>

        <!-- CBSE Disclosure Badge -->
        <a
          href="/disclosure"
          class="flex items-center gap-3 p-4 rounded-xl bg-emerald-900/30 border border-emerald-700/50 hover:bg-emerald-900/50 transition-all group"
        >
          <div class="w-10 h-10 rounded-lg bg-emerald-600 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-emerald-300 group-hover:text-emerald-200 transition-colors">Mandatory Public Disclosure</p>
            <p class="text-xs text-slate-500">As per CBSE Guidelines</p>
          </div>
        </a>
      </div>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-sm text-slate-500 text-center md:text-left">
          &copy; {currentYear} Knowledge Development Kindergarten Academy. All rights reserved.
        </p>
        <div class="flex items-center gap-6">
          <a href="#" class="text-xs text-slate-500 hover:text-primary-400 transition-colors">Privacy Policy</a>
          <a href="#" class="text-xs text-slate-500 hover:text-primary-400 transition-colors">Terms of Use</a>
          <a href="/disclosure" class="text-xs text-slate-500 hover:text-primary-400 transition-colors">CBSE Disclosure</a>
        </div>
      </div>
    </div>
  </div>
</footer>
