---
import BaseLayout from "../layouts/BaseLayout.astro";

const facilities = [
  {
    title: "Digital Library",
    desc: "A rich inventory of 5,000+ reference books, academic journals, early learning storybooks, and a set of computers providing digital encyclopedias.",
    image: "https://images.unsplash.com/photo-1521587760476-6c12a4b040da?w=600&fit=crop",
    reverse: false,
  },
  {
    title: "Integrated Science Lab",
    desc: "Equipped with safety apparatus, microscopes, and chemical models, letting middle and secondary students perform hands-on physics, chemistry, and biology experiments.",
    image: "https://images.unsplash.com/photo-1562774053-701939374585?w=600&fit=crop",
    reverse: true,
  },
  {
    title: "ICT Computer Lab",
    desc: "Modern desktops with high-speed internet connections and structured coding programs to introduce students to basic programming and information technology.",
    image: "https://images.unsplash.com/photo-1547480172-3c2904b1d97f?w=600&fit=crop",
    reverse: false,
  },
  {
    title: "Smart Classrooms",
    desc: "Every classroom features a high-definition interactive projector and audio systems, facilitating graphical slide decks and multi-media learning.",
    image: "https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=600&fit=crop",
    reverse: true,
  },
];
---

<BaseLayout title="Facilities — Knowledge Development Kindergarten Academy">
  <!-- Banner -->
  <section class="bg-gradient-to-br from-indigo-900 via-indigo-850 to-indigo-950 text-white py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-4">
      <h1 class="text-4xl md:text-5xl font-extrabold font-heading">Campus Facilities</h1>
      <p class="text-indigo-200 text-lg max-w-xl mx-auto">
        A well-equipped, safe, and modern campus infrastructure built to support comprehensive learning and physical development.
      </p>
    </div>
  </section>

  <!-- Facilities list -->
  <section class="max-w-6xl mx-auto px-4 py-20 space-y-20">
    {facilities.map((fac, index) => (
      <div class={`grid grid-cols-1 md:grid-cols-2 gap-12 items-center ${fac.reverse ? 'md:flex-row-reverse' : ''}`}>
        <div class={`space-y-6 ${fac.reverse ? 'md:order-2' : ''}`}>
          <div class="inline-block px-3 py-1 bg-indigo-50 text-indigo-700 rounded-full font-bold text-sm">
            Facility 0{index + 1}
          </div>
          <h2 class="text-3xl font-extrabold font-heading text-slate-900 leading-tight">
            {fac.title}
          </h2>
          <p class="text-slate-600 leading-relaxed font-semibold">
            {fac.desc}
          </p>
          <p class="text-slate-500 text-sm leading-relaxed">
            All campus facilities undergo regular safety audits and cleanups. Faculty members supervise students at all times.
          </p>
        </div>
        
        <div class={`relative ${fac.reverse ? 'md:order-1' : ''}`}>
          <div class="absolute -inset-4 bg-indigo-500/10 rounded-3xl rotate-2 -z-10"></div>
          <img
            src={fac.image}
            alt={fac.title}
            class="w-full h-auto object-cover rounded-3xl shadow-md aspect-[4/3]"
          />
        </div>
      </div>
    ))}
  </section>

  <!-- Playground & Medical details -->
  <section class="bg-slate-50 border-t border-slate-100 py-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm space-y-4">
          <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0l-1.414-1.414a4 4 0 010-5.656l1.414-1.414a4 4 0 015.656 0l1.414 1.414a4 4 0 010 5.656l-1.414 1.414z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-800">Playground & Physical Education</h3>
          <p class="text-sm text-slate-500 font-semibold leading-relaxed">
            A secured, grassy sports playground offering setups for football, basketball, and basic running tracks, hosting daily supervised games and physical drills.
          </p>
        </div>

        <div class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm space-y-4">
          <div class="w-12 h-12 bg-rose-50 text-rose-600 rounded-2xl flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold text-slate-800">First-Aid Room & Hygiene</h3>
          <p class="text-sm text-slate-500 font-semibold leading-relaxed">
            Staffed with a dedicated first-aid specialist, providing resting beds, essential medicine supplies, and tie-ups with nearby healthcare facilities for emergencies.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
