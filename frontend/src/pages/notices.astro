---
import BaseLayout from "../layouts/BaseLayout.astro";
import NoticesList from "../components/public/NoticesList.tsx";
---

<BaseLayout title="Notices & Circulars — Knowledge Development Kindergarten Academy">
  <!-- Banner -->
  <section class="bg-gradient-to-br from-indigo-900 via-indigo-850 to-indigo-950 text-white py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-4">
      <h1 class="text-4xl md:text-5xl font-extrabold font-heading">Notices & Circulars</h1>
      <p class="text-indigo-200 text-lg max-w-xl mx-auto">
        Stay updated with school schedules, holiday calendars, datesheets, and general announcements.
      </p>
    </div>
  </section>

  <!-- Notices List (live from backend, with built-in fallback) -->
  <section class="max-w-4xl mx-auto px-4 py-20 space-y-8">
    <NoticesList client:load />
  </section>
</BaseLayout>
