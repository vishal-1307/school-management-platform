---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSchoolInfo } from "../lib/schoolInfo";

const school = await getSchoolInfo();

const generalInfo = [
  { key: "Establishment Year", value: String(school.establishedYear) },
  { key: "Recognition Status", value: "Recognised by the State Government of Bihar" },
  { key: "CBSE Affiliation", value: "In process — not yet granted" },
  { key: "Official Address", value: school.address },
  { key: "Contact Phone", value: `${school.contactPhone} / ${school.contactPhoneAlt}` },
  { key: "Contact Email", value: school.contactEmail },
];

// CBSE-required disclosure documents apply once affiliation is granted.
// Publishing fake "#" download links for these would misrepresent the
// school's actual (pending) affiliation status — so this list states
// status honestly instead of linking to non-existent files.
const documents = [
  "CBSE Affiliation Letter",
  "Society/Trust Registration Certificate",
  "No Objection Certificate (NOC) from State Govt.",
  "Recognition Certificate under RTE Act, 2009",
  "Valid Building Safety Certificate",
  "Valid Fire Safety Certificate",
  "Self-Certification / Water & Sanitation Certificate",
  "List of School Management Committee (SMC)",
];
---

<BaseLayout title="Public Disclosure — Knowledge Development Kindergarten Academy">
  <!-- Banner -->
  <section class="bg-gradient-to-br from-indigo-900 via-indigo-850 to-indigo-950 text-white py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-4">
      <h1 class="text-4xl md:text-5xl font-extrabold font-heading">Public Disclosure</h1>
      <p class="text-indigo-200 text-lg max-w-xl mx-auto">
        General information about the school, published for public transparency. CBSE affiliation is currently
        in process — the CBSE-specific disclosure documents below will be published here once affiliation is granted.
      </p>
    </div>
  </section>

  <!-- General Info Table -->
  <section class="max-w-4xl mx-auto px-4 py-20 space-y-12">
    <div class="space-y-4">
      <h2 class="text-2xl font-extrabold font-heading text-slate-800">A. General Information</h2>
      <div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
        <table class="w-full text-left text-sm font-semibold">
          <tbody class="divide-y divide-slate-150 text-slate-600">
            {generalInfo.map((info, index) => (
              <tr class={index % 2 === 0 ? "bg-slate-50" : "bg-white"}>
                <td class="p-4 font-bold text-slate-800 w-1/3 border-r border-slate-150">{info.key}</td>
                <td class="p-4">{info.value}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Documents List -->
    <div class="space-y-4 pt-8">
      <h2 class="text-2xl font-extrabold font-heading text-slate-800">B. CBSE Disclosure Documents</h2>
      <p class="text-sm text-slate-500 font-semibold">
        These documents apply once CBSE affiliation is granted. The school's affiliation is currently in
        process, so these are not yet available — they will be published here as soon as affiliation comes through.
      </p>
      <div class="border border-slate-200 rounded-2xl overflow-hidden shadow-sm divide-y divide-slate-150">
        {documents.map((doc, index) => (
          <div class={`flex justify-between items-center p-5 ${index % 2 === 0 ? 'bg-slate-50' : 'bg-white'}`}>
            <span class="text-sm font-semibold text-slate-700 leading-normal w-2/3">{doc}</span>
            <span class="px-4 py-2 bg-amber-50 text-amber-700 font-bold rounded-xl text-xs flex items-center gap-1.5 border border-amber-100">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              Pending Affiliation
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
