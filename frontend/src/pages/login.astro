---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Portal Login Gateway — Knowledge Development Kindergarten Academy">
  <section class="min-h-[80vh] flex flex-col justify-center items-center py-20 px-4 bg-slate-50">
    <div class="max-w-md w-full text-center space-y-4 mb-12">
      <h1 class="text-3xl md:text-4xl font-extrabold font-heading text-slate-900 leading-tight">Academy Portals</h1>
      <p class="text-slate-500 font-semibold text-sm">
        Select your role below to access secure dashboard modules, timetables, and academic records.
      </p>
    </div>

    <div class="max-w-4xl w-full grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Admin Card -->
      <a
        href="#"
        class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition duration-300 flex flex-col items-center text-center space-y-4 group"
      >
        <div class="w-16 h-16 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center group-hover:bg-indigo-600 group-hover:text-white transition duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
        </div>
        <div class="space-y-1">
          <h3 class="text-xl font-extrabold text-slate-800">Admin Portal</h3>
          <p class="text-xs text-slate-400 font-bold uppercase tracking-wider">Owner / Office Staff</p>
        </div>
        <p class="text-xs text-slate-500 font-semibold leading-relaxed">
          Manage enrollments, assign classes, structure term fees, publish notices, and edit CBSE disclosures.
        </p>
      </a>

      <!-- Teacher Card -->
      <a
        href="#"
        class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition duration-300 flex flex-col items-center text-center space-y-4 group"
      >
        <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center group-hover:bg-emerald-600 group-hover:text-white transition duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        </div>
        <div class="space-y-1">
          <h3 class="text-xl font-extrabold text-slate-800">Teacher Portal</h3>
          <p class="text-xs text-emerald-600 font-bold uppercase tracking-wider">Teaching Faculty</p>
        </div>
        <p class="text-xs text-slate-500 font-semibold leading-relaxed">
          Mark daily class attendance, assign homework files, enter exam marks, and apply for leaves.
        </p>
      </a>

      <!-- Student Card -->
      <a
        href="#"
        class="bg-white p-8 rounded-3xl border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition duration-300 flex flex-col items-center text-center space-y-4 group"
      >
        <div class="w-16 h-16 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center group-hover:bg-amber-600 group-hover:text-white transition duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222" /></svg>
        </div>
        <div class="space-y-1">
          <h3 class="text-xl font-extrabold text-slate-800">Student Portal</h3>
          <p class="text-xs text-amber-600 font-bold uppercase tracking-wider">Enrolled Students</p>
        </div>
        <p class="text-xs text-slate-500 font-semibold leading-relaxed">
          View weekly timetable slots, check attendance records, download datesheets, and check fee transaction history.
        </p>
      </a>
    </div>
  </section>
</BaseLayout>
