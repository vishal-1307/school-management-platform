---
import BaseLayout from "../layouts/BaseLayout.astro";

const levels = [
  {
    name: "Pre-Primary (Playgroup to UKG)",
    focus: "Early learning, sensory development, basic language and numeracy skills, interactive playtime.",
    subjects: ["English Language", "Mathematics (Basic)", "Environmental Studies", "Rhymes & Storytelling", "Drawing & Craft"],
  },
  {
    name: "Primary (Class 1 to 5)",
    focus: "Conceptual understanding, creative exploration, communication skills, moral values.",
    subjects: ["English", "Hindi", "Mathematics", "Environmental Studies (EVS)", "Computer Studies", "General Knowledge", "Art & Craft"],
  },
  {
    name: "Middle School (Class 6 to 8)",
    focus: "Analytical reasoning, scientific inquiry, logical problem-solving, structured science/social sciences.",
    subjects: ["English", "Hindi", "Sanskrit / Regional Language", "Mathematics", "Science (Physics, Chemistry, Biology)", "Social Science", "Computer Application"],
  },
  {
    name: "Secondary School (Class 9 & 10)",
    focus: "Board exam preparation, advanced logical application, research skills, career pathway guidance.",
    subjects: ["English Communicative", "Hindi / Sanskrit", "Mathematics", "Science", "Social Science", "Information Technology (IT)"],
  },
];
---

<BaseLayout title="Academics — Knowledge Development Kindergarten Academy">
  <!-- Banner -->
  <section class="bg-gradient-to-br from-indigo-900 via-indigo-850 to-indigo-950 text-white py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-4">
      <h1 class="text-4xl md:text-5xl font-extrabold font-heading">Academic Program</h1>
      <p class="text-indigo-200 text-lg max-w-xl mx-auto">
        A structured, CBSE-compliant curriculum that prioritizes analytical thinking, conceptual clarity, and values.
      </p>
    </div>
  </section>

  <!-- Overview -->
  <section class="max-w-6xl mx-auto px-4 py-20 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
    <div class="lg:col-span-7 space-y-6">
      <div class="inline-block px-3 py-1 bg-indigo-50 text-indigo-700 rounded-full font-bold text-sm">
        Curriculum Guidelines
      </div>
      <h2 class="text-3xl font-extrabold font-heading text-slate-900 leading-tight">
        A Comprehensive CBSE Curriculum designed for Modern Challenges
      </h2>
      <p class="text-slate-600 leading-relaxed font-semibold">
        Knowledge Development Kindergarten Academy follows the Central Board of Secondary Education (CBSE) syllabus, ensuring conformity to national educational parameters.
      </p>
      <p class="text-slate-600 leading-relaxed">
        Our teachers utilize smart classroom tools, digital learning assets, and continuous assessment plans to monitor each child's academic development. We emphasize continuous evaluation and regular feedback cycles.
      </p>
      <div class="pt-4">
        <a
          href="/academic-calendar-placeholder.pdf"
          class="inline-flex items-center gap-2 px-6 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition shadow hover:shadow-indigo-600/10"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
          Download Academic Calendar (PDF)
        </a>
      </div>
    </div>
    <div class="lg:col-span-5 relative">
      <img
        src="https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?w=600&fit=crop"
        alt="Students studying"
        class="w-full h-auto object-cover rounded-3xl shadow-md aspect-[4/3]"
      />
    </div>
  </section>

  <!-- Level Details -->
  <section class="bg-slate-50 py-20 border-y border-slate-100">
    <div class="max-w-6xl mx-auto px-4 space-y-12">
      <div class="text-center max-w-2xl mx-auto space-y-4">
        <h2 class="text-3xl font-extrabold font-heading text-slate-900">Academic Stages & Subjects</h2>
        <p class="text-slate-500 font-semibold">
          Explore stage-wise curriculum highlights, learning focuses, and list of subjects.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {levels.map(level => (
          <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition duration-300 space-y-6">
            <div class="space-y-2">
              <h3 class="text-xl font-extrabold text-indigo-600 font-heading">{level.name}</h3>
              <p class="text-sm text-slate-500 font-semibold leading-relaxed">{level.focus}</p>
            </div>
            <div class="space-y-3">
              <h4 class="font-bold text-slate-800 text-xs uppercase tracking-wider">Key Subjects Offered</h4>
              <div class="flex flex-wrap gap-2">
                {level.subjects.map(sub => (
                  <span class="px-3 py-1.5 bg-slate-100 text-slate-700 rounded-lg text-xs font-bold">{sub}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Teaching Methodology -->
  <section class="max-w-6xl mx-auto px-4 py-20 space-y-16">
    <div class="text-center max-w-2xl mx-auto space-y-4">
      <h2 class="text-3xl font-extrabold font-heading text-slate-900">Our Teaching Methodologies</h2>
      <p class="text-slate-500 font-semibold">
        How we make education engaging, practical, and digital-friendly.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="p-6 bg-white border border-slate-100 rounded-2xl shadow-sm text-center space-y-4">
        <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        </div>
        <h3 class="text-lg font-bold text-slate-800">Smart Classrooms</h3>
        <p class="text-sm text-slate-500 font-semibold leading-relaxed">
          Integrating interactive digital boards, multi-media content, and slides to simplify complex scientific and mathematical concepts.
        </p>
      </div>

      <div class="p-6 bg-white border border-slate-100 rounded-2xl shadow-sm text-center space-y-4">
        <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
        </div>
        <h3 class="text-lg font-bold text-slate-800">Activity-Based Learning</h3>
        <p class="text-sm text-slate-500 font-semibold leading-relaxed">
          Promoting regular lab visits, environmental science activities, project works, and group discussions to encourage practical thinking.
        </p>
      </div>

      <div class="p-6 bg-white border border-slate-100 rounded-2xl shadow-sm text-center space-y-4">
        <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center mx-auto">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        </div>
        <h3 class="text-lg font-bold text-slate-800">Values & Life Skills</h3>
        <p class="text-sm text-slate-500 font-semibold leading-relaxed">
          Weekly moral science discussions, communication skills workshops, and inclusive group games to build emotional intelligence.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
