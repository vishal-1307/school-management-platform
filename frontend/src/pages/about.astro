---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSchoolInfo } from "../lib/schoolInfo";

const school = await getSchoolInfo();
---

<BaseLayout title="About Us — Knowledge Development Kindergarten Academy">
  <!-- Banner -->
  <section class="bg-gradient-to-br from-indigo-900 via-indigo-850 to-indigo-950 text-white py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto space-y-4">
      <h1 class="text-4xl md:text-5xl font-extrabold font-heading">About Our Academy</h1>
      <p class="text-indigo-200 text-lg max-w-xl mx-auto">
        Learn about our history, mission, vision, and the values that drive our educational community.
      </p>
    </div>
  </section>

  <!-- Vision, Mission, Values -->
  <section class="max-w-6xl mx-auto px-4 py-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition space-y-4">
        <div class="w-12 h-12 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
        </div>
        <h3 class="text-xl font-extrabold text-slate-800">Our Vision</h3>
        <p class="text-slate-500 font-semibold leading-relaxed">
          To build a premier educational foundation that nurtures intellectual curiosity, social responsibility, and international awareness in every child.
        </p>
      </div>

      <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition space-y-4">
        <div class="w-12 h-12 bg-emerald-50 text-emerald-600 rounded-xl flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        </div>
        <h3 class="text-xl font-extrabold text-slate-800">Our Mission</h3>
        <p class="text-slate-500 font-semibold leading-relaxed">
          Providing student-centered instruction, integrating digital resources, and maintaining safety protocols to ensure students acquire both academic mastery and values.
        </p>
      </div>

      <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:shadow-md transition space-y-4">
        <div class="w-12 h-12 bg-amber-50 text-amber-600 rounded-xl flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
        </div>
        <h3 class="text-xl font-extrabold text-slate-800">Core Values</h3>
        <p class="text-slate-500 font-semibold leading-relaxed">
          Integrity, Empathy, Curiosity, and Inclusivity are the pillars of the academy, encouraging respect for diverse backgrounds.
        </p>
      </div>
    </div>
  </section>

  <!-- Principal's Message -->
  <section class="bg-slate-50 py-20 border-y border-slate-100">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-4">
          <img
            src="https://images.unsplash.com/photo-1544717305-2782549b5136?w=500&fit=crop"
            alt="School Principal"
            class="w-full h-auto object-cover rounded-3xl shadow-md aspect-[3/4]"
          />
        </div>
        <div class="lg:col-span-8 space-y-6">
          <h2 class="text-3xl font-extrabold font-heading text-slate-900">Message from the Principal</h2>
          <p class="text-slate-600 leading-relaxed">
            Dear Parents, Guardians, and Well-wishers,
          </p>
          <p class="text-slate-600 leading-relaxed">
            It is my privilege to welcome you to Knowledge Development Kindergarten Academy. Education is a journey that goes beyond classroom walls. Our focus is to provide a balanced curriculum that cultivates self-confidence, creativity, and a sense of responsibility.
          </p>
          <p class="text-slate-600 leading-relaxed">
            We work closely with parents to keep track of student attendance, results, and fees, utilizing a highly advanced parent communication channel over WhatsApp. Together, we look forward to supporting your child’s educational journey and nurturing their aspirations.
          </p>
          <div class="pt-4 border-t border-slate-200">
            <h4 class="font-bold text-slate-800">Mrs. Anita Sharma</h4>
            <p class="text-sm text-slate-500 font-semibold">Principal, M.A., B.Ed.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- History & Timeline -->
  <section class="max-w-4xl mx-auto px-4 py-20 space-y-12">
    <div class="text-center space-y-4">
      <h2 class="text-3xl font-extrabold font-heading text-slate-900">Our History & Legacy</h2>
      <p class="text-slate-500 font-semibold max-w-lg mx-auto">
        Tracing the path of our academy from its humble beginnings to a modern center of learning.
      </p>
    </div>

    <div class="relative border-l-2 border-indigo-100 pl-8 ml-4 space-y-12">
      <!-- 2005 — confirmed: school's own signage/Facebook page both say "Estd. 2005" -->
      <div class="relative">
        <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full border-4 border-white bg-indigo-600 shadow-sm"></div>
        <div class="space-y-2">
          <span class="text-indigo-600 font-extrabold text-lg">2005</span>
          <h3 class="font-bold text-slate-800">Foundation Stone</h3>
          <p class="text-slate-500 font-semibold leading-relaxed">
            Founded as an English-medium kindergarten school in Benipatti, recognised by the State Government of Bihar.
          </p>
        </div>
      </div>

      <!-- Unconfirmed milestone years below — placeholder timeline pending real history from the school -->
      <div class="relative">
        <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full border-4 border-white bg-indigo-600 shadow-sm"></div>
        <div class="space-y-2">
          <span class="text-indigo-600 font-extrabold text-lg">Growing Years</span>
          <h3 class="font-bold text-slate-800">Expansion to Class 10</h3>
          <p class="text-slate-500 font-semibold leading-relaxed">
            Grew from kindergarten to a full school offering Pre-Nursery through Class 10, with a boys' hostel for outstation students.
          </p>
        </div>
      </div>

      <!-- CBSE affiliation is currently in process, not yet granted — see the school's own current marketing. Do not claim it as obtained. -->
      <div class="relative">
        <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full border-4 border-white bg-indigo-600 shadow-sm"></div>
        <div class="space-y-2">
          <span class="text-indigo-600 font-extrabold text-lg">In Progress</span>
          <h3 class="font-bold text-slate-800">CBSE Affiliation (Pending)</h3>
          <p class="text-slate-500 font-semibold leading-relaxed">
            The academy currently follows a CBSE-pattern curriculum and is in the process of seeking formal CBSE affiliation.
          </p>
        </div>
      </div>

      <!-- 2026 -->
      <div class="relative">
        <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full border-4 border-white bg-indigo-600 shadow-sm"></div>
        <div class="space-y-2">
          <span class="text-indigo-600 font-extrabold text-lg">2026</span>
          <h3 class="font-bold text-slate-800">Digital-Ready Institution</h3>
          <p class="text-slate-500 font-semibold leading-relaxed">
            Implemented a completely paperless school management portal, linking parent notifications, fees, and report cards directly to WhatsApp.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Affiliation Card -->
  <section class="max-w-6xl mx-auto px-4 pb-20">
    <div class="bg-indigo-900 text-white rounded-3xl p-10 flex flex-col md:flex-row gap-8 items-center justify-between shadow-lg">
      <div class="space-y-2">
        <h3 class="text-2xl font-bold font-heading">Recognition & Affiliation</h3>
        <p class="text-indigo-200 font-semibold">
          Recognised by the State Government of Bihar. CBSE affiliation is currently in process — this page will be updated once granted.
        </p>
      </div>
      <a
        href="/disclosure"
        class="px-6 py-3 bg-amber-500 hover:bg-amber-600 text-slate-950 font-bold rounded-xl transition duration-300 shadow"
      >
        View Public Disclosure
      </a>
    </div>
  </section>
</BaseLayout>
