# Backend API base URL (Render service URL in production)
PUBLIC_API_URL=http://localhost:8000

# Signs/verifies session JWTs for the middleware's role-gating. Must be the
# EXACT SAME value as the backend's SECRET_KEY (copy it from Render).
# If left unset, middleware falls back to an unverified decode for coarse
# routing only — the backend API remains the real authority either way.
SECRET_KEY=change-me-to-a-long-random-string
